<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="MonarchERP" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20"
              rightMargin="20" topMargin="20" bottomMargin="20">
    <parameter name="INVOICE_ID" class="java.lang.Long"/>

    <query language="sql">
        <![CDATA[SELECT
            p.product_name,
            v.variant_name,
            (v.colour || ' / ' || v.size) AS product_details,
            c.name, c.email, c.mobile,
            s.discount_amount, s.grand_total,
            s.invoice_number,s.invoice_date,
            si.quantity, si.unit_price, si.line_total
        FROM sales_items si
        JOIN variants v ON v.variant_id = si.variant_id
        JOIN products p ON p.product_id = v.product_id
        JOIN sales_invoices s ON s.id = si.invoice_id
        JOIN customers c ON c.id = s.customer_id
        WHERE si.invoice_id = $P{INVOICE_ID}
          AND v.deleted_variant = false
          AND p.deleted_prod = false]]>
    </query>

    <field name="product_name" class="java.lang.String"/>
    <field name="variant_name" class="java.lang.String"/>
    <field name="product_details" class="java.lang.String"/>
    <field name="quantity" class="java.lang.Integer"/>
    <field name="unit_price" class="java.lang.Double"/>
    <field name="line_total" class="java.lang.Double"/>
    <field name="discount_amount" class="java.lang.Double"/>
    <field name="invoice_number" class="java.lang.String"/>
    <field name="invoice_date" class="java.util.Date"/>
    <field name="name" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="mobile" class="java.lang.String"/>

    <variable name="SubtotalVar" class="java.lang.Double" calculation="Sum">
        <expression><![CDATA[$F{line_total}]]></expression>
    </variable>

    <pageHeader height="30">
        <element kind="textField" x="0" y="5" width="200" height="20" fontSize="9.0" forecolor="#444444">
            <expression>
                <![CDATA[new java.text.SimpleDateFormat("d/M/yy, h:mm a").format(new java.util.Date())]]></expression>
        </element>
        <element kind="staticText" x="200" y="5" width="355" height="20" fontSize="10.0" hTextAlign="Center"
                 vTextAlign="Middle">
            <text><![CDATA[Monarch ERP | Recent Sales]]></text>
        </element>
    </pageHeader>
    <element kind="staticText" x="0" y="10" width="400" height="50" fontSize="42.0" bold="true" forecolor="#007BFF">
        <text><![CDATA[MONARCH]]></text>
    </element>
    <element kind="staticText" x="0" y="55" width="400" height="25" fontSize="18.0" bold="true" forecolor="#666666">
        <text><![CDATA[ERP SOLUTIONS]]></text>
    </element>

    <title height="200">
        <element kind="staticText" x="0" y="10" width="350" height="50" fontSize="42.0" bold="true" forecolor="#007BFF">
            <text><![CDATA[MONARCH]]></text>
        </element>
        <element kind="staticText" x="0" y="55" width="350" height="25" fontSize="18.0" bold="true" forecolor="#666666">
            <text><![CDATA[ERP SOLUTIONS]]></text>
        </element>

        <element kind="rectangle" x="0" y="95" width="555" height="4" backcolor="#007BFF" forecolor="#007BFF">
            <pen lineWidth="0.0"/>
        </element>

        <element kind="frame" x="0" y="110" width="555" height="85">
            <element kind="staticText" x="0" y="5" width="100" height="12" fontSize="9.0" bold="true"
                     forecolor="#666666">
                <text><![CDATA[BILLED TO]]></text>
            </element>
            <element kind="textField" x="0" y="18" width="250" height="20" fontSize="14.0" bold="true">
                <expression><![CDATA[$F{name}]]></expression>
            </element>
            <element kind="textField" x="0" y="38" width="250" height="15" fontSize="10.0" forecolor="#555555">
                <expression><![CDATA[$F{email}]]></expression>
            </element>
            <element kind="textField" x="0" y="53" width="250" height="15" fontSize="10.0" forecolor="#555555">
                <expression><![CDATA[$F{mobile}]]></expression>
            </element>

            <element kind="staticText" x="380" y="5" width="175" height="12" fontSize="9.0" bold="true"
                     forecolor="#666666" hTextAlign="Right">
                <text><![CDATA[INVOICE DETAILS]]></text>
            </element>
            <element kind="textField" x="380" y="18" width="175" height="20" fontSize="14.0" bold="true"
                     forecolor="#007BFF" hTextAlign="Right">
                <expression><![CDATA[$F{invoice_number}]]></expression>
            </element>
            <element kind="textField" x="380" y="38" width="175" height="15" hTextAlign="Right" fontSize="10.0">
                <expression>
                    <![CDATA["Date: " + new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{invoice_date})]]></expression>
            </element>

            <element kind="staticText" x="380" y="58" width="75" height="15" fontSize="9.0" bold="true"
                     forecolor="#666666" hTextAlign="Right">
                <text><![CDATA[STATUS:]]></text>
            </element>
            <element kind="staticText" x="455" y="58" width="100" height="15" fontSize="10.0" bold="true"
                     forecolor="#28A745" hTextAlign="Right">
                <text><![CDATA[PAID]]></text>
            </element>


        </element>

    </title>

    <columnHeader height="30">
        <element kind="frame" x="0" y="0" width="555" height="30" backcolor="#F8F9FA">
            <box>
                <bottomPen lineWidth="1.0" lineColor="#EEEEEE"/>
            </box>
            <element kind="staticText" x="10" y="5" width="230" height="20" bold="true" vTextAlign="Middle">
                <text><![CDATA[PRODUCT DESCRIPTION]]></text>
            </element>
            <element kind="staticText" x="250" y="5" width="70" height="20" bold="true" hTextAlign="Center"
                     vTextAlign="Middle">
                <text><![CDATA[QTY]]></text>
            </element>
            <element kind="staticText" x="330" y="5" width="100" height="20" bold="true" hTextAlign="Right"
                     vTextAlign="Middle">
                <text><![CDATA[PRICE]]></text>
            </element>
            <element kind="staticText" x="445" y="5" width="100" height="20" bold="true" hTextAlign="Right"
                     vTextAlign="Middle">
                <text><![CDATA[TOTAL]]></text>
            </element>
        </element>
    </columnHeader>

    <detail>
        <band height="40">
            <element kind="textField" x="10" y="5" width="230" height="15" bold="true">
                <expression><![CDATA[$F{product_name} + " (" + $F{variant_name} + ")"]]></expression>
            </element>
            <element kind="textField" x="10" y="20" width="230" height="12" fontSize="9.0" forecolor="#666666">
                <expression><![CDATA[$F{product_details}]]></expression>
            </element>
            <element kind="textField" x="250" y="10" width="70" height="15" hTextAlign="Center" vTextAlign="Middle">
                <expression><![CDATA[$F{quantity}]]></expression>
            </element>
            <element kind="textField" x="330" y="10" width="100" height="15" hTextAlign="Right" vTextAlign="Middle"
                     pattern="₹ #,##0.00">
                <expression><![CDATA[$F{unit_price}]]></expression>
            </element>
            <element kind="textField" x="445" y="10" width="100" height="15" hTextAlign="Right" vTextAlign="Middle"
                     bold="true" pattern="₹ #,##0.00">
                <expression><![CDATA[$F{line_total}]]></expression>
            </element>
            <element kind="line" x="0" y="39" width="555" height="1" forecolor="#F0F0F0"/>
        </band>
    </detail>

    <summary height="120">
        <element kind="frame" x="330" y="10" width="225" height="90">
            <element kind="staticText" x="10" y="5" width="100" height="20" fontSize="11.0">
                <text><![CDATA[Subtotal]]></text>
            </element>
            <element kind="textField" x="110" y="5" width="105" height="20" hTextAlign="Right" fontSize="11.0"
                     pattern="₹ #,##0.00">
                <expression><![CDATA[$V{SubtotalVar}]]></expression>
            </element>

            <element kind="staticText" x="10" y="25" width="100" height="20" fontSize="11.0">
                <text><![CDATA[Discount]]></text>
            </element>
            <element kind="textField" x="110" y="25" width="105" height="20" hTextAlign="Right" fontSize="11.0"
                     forecolor="#CC0000" pattern="- ₹ #,##0.00">
                <expression><![CDATA[$F{discount_amount}]]></expression>
            </element>

            <element kind="line" x="10" y="50" width="205" height="1" forecolor="#0056B3"/>

            <element kind="staticText" x="10" y="55" width="100" height="25" fontSize="12.0" bold="true"
                     vTextAlign="Middle">
                <text><![CDATA[Grand Total]]></text>
            </element>
            <element kind="textField" x="110" y="55" width="105" height="25" hTextAlign="Right" vTextAlign="Middle"
                     fontSize="15.0" bold="true" forecolor="#0056B3" pattern="₹ #,##0.00">
                <expression>
                    <![CDATA[$V{SubtotalVar} - ($F{discount_amount} != null ? $F{discount_amount} : 0.0)]]></expression>
            </element>
        </element>
        <element kind="staticText" x="0" y="100" width="555" height="20" fontSize="8.0" forecolor="#999999"
                 hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[Thank you for choosing Monarch ERP! This is a computer-generated invoice.]]></text>
        </element>
    </summary>
</jasperReport>