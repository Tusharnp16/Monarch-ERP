<?xml version="1.0" encoding="UTF-8"?>

<jasperReport name="MonarchERP" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" >
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MonarchERP"/>
		<parameter name="INVOICE_ID" class="java.lang.Long"/>

		<query language="sql">
			<![CDATA[SELECT p.product_name, (v.colour || ' / ' || v.size) AS product_details, si.quantity, si.unit_price, si.line_total
        FROM sales_items si
        JOIN variants v ON v.variant_id = si.variant_id
        JOIN products p ON p.product_id = v.product_id
        WHERE si.invoice_id = $P{INVOICE_ID} AND v.deleted_variant = false AND p.deleted_prod = false]]>
		</query>

		<field name="product_name" class="java.lang.String"/>
		<field name="product_details" class="java.lang.String"/>
		<field name="quantity" class="java.lang.Integer"/>
		<field name="unit_price" class="java.lang.Double"/>
		<field name="line_total" class="java.lang.Double"/>

	<variable name="TotalDue" class="java.lang.Double" calculation="Sum">
		<expression><![CDATA[$F{line_total}]]></expression>
	</variable>

		<title height="140">
			<element kind="staticText" x="0" y="0" width="280" height="40" fontSize="24.0" bold="true" forecolor="#0056B3">
				<text><![CDATA[MONARCH ERP]]></text>
			</element>
			<element kind="staticText" x="380" y="0" width="175" height="30" fontSize="20.0" bold="true" hTextAlign="Right">
				<text><![CDATA[INVOICE]]></text>
			</element>
			<element kind="textField" x="380" y="30" width="175" height="20" hTextAlign="Right">
				<expression><![CDATA["Date: " + new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.util.Date())]]></expression>
			</element>
			<element kind="frame" x="0" y="70" width="555" height="60">
				<box><pen lineWidth="0.5" lineColor="#DEDEDE"/></box>
				<element kind="staticText" x="10" y="5" width="100" height="15" fontSize="10.0" bold="true" forecolor="#666666">
					<text><![CDATA[BILLED TO]]></text>
				</element>
				<element kind="staticText" x="10" y="20" width="200" height="20" fontSize="12.0" bold="true">
					<text><![CDATA[Tushar Parmar]]></text>
				</element>
				<element kind="staticText" x="445" y="5" width="100" height="15" fontSize="10.0" bold="true" forecolor="#666666" hTextAlign="Right">
					<text><![CDATA[PAYMENT STATUS]]></text>
				</element>
				<element kind="staticText" x="445" y="20" width="100" height="20" fontSize="11.0" bold="true" forecolor="#28A745" hTextAlign="Right">
					<text><![CDATA[COMPLETED]]></text>
				</element>
			</element>
		</title>

		<columnHeader height="30">
			<element kind="frame" x="0" y="0" width="555" height="30" backcolor="#F8F9FA">
				<box><bottomPen lineWidth="1.0" lineColor="#EEEEEE"/></box>
				<element kind="staticText" x="10" y="5" width="200" height="20" bold="true"><text><![CDATA[PRODUCT]]></text></element>
				<element kind="staticText" x="220" y="5" width="100" height="20" bold="true" hTextAlign="Center"><text><![CDATA[QTY]]></text></element>
				<element kind="staticText" x="330" y="5" width="100" height="20" bold="true" hTextAlign="Right"><text><![CDATA[PRICE]]></text></element>
				<element kind="staticText" x="445" y="5" width="100" height="20" bold="true" hTextAlign="Right"><text><![CDATA[TOTAL]]></text></element>
			</element>
		</columnHeader>

		<detail>
			<band height="35">
				<element kind="textField" x="10" y="5" width="200" height="15" bold="true">
					<expression><![CDATA[$F{product_name}]]></expression>
				</element>
				<element kind="textField" x="10" y="20" width="200" height="12" fontSize="9.0" forecolor="#666666">
					<expression><![CDATA[$F{product_details}]]></expression>
				</element>
				<element kind="textField" x="220" y="10" width="100" height="15" hTextAlign="Center">
					<expression><![CDATA[$F{quantity}]]></expression>
				</element>
				<element kind="textField" x="330" y="10" width="100" height="15" hTextAlign="Right" pattern="₹ #,##0">
					<expression><![CDATA[$F{unit_price}]]></expression>
				</element>
				<element kind="textField" x="445" y="10" width="100" height="15" hTextAlign="Right" bold="true" pattern="₹ #,##0">
					<expression><![CDATA[$F{line_total}]]></expression>
				</element>
				<element kind="line" x="0" y="34" width="555" height="1" forecolor="#F0F0F0"/>
			</band>
		</detail>

		<summary height="100">
			<element kind="frame" x="330" y="20" width="225" height="60">
				<element kind="staticText" x="10" y="5" width="100" height="20" fontSize="11.0"><text><![CDATA[Subtotal]]></text></element>
				<element kind="textField" x="110" y="5" width="105" height="20" hTextAlign="Right" fontSize="11.0" pattern="₹ #,##0.00">
					<expression><![CDATA[$V{TotalDue}]]></expression>
				</element>
				<element kind="line" x="10" y="30" width="205" height="1" forecolor="#EEEEEE"/>
				<element kind="staticText" x="10" y="35" width="100" height="20" fontSize="12.0" bold="true"><text><![CDATA[Total Due]]></text></element>
				<element kind="textField" x="110" y="35" width="105" height="20" hTextAlign="Right" fontSize="14.0" bold="true" forecolor="#0056B3" pattern="₹ #,##0.00">
					<expression><![CDATA[$V{TotalDue}]]></expression>
				</element>
			</element>
			<element kind="staticText" x="0" y="80" width="555" height="20" fontSize="9.0" forecolor="#999999" hTextAlign="Center" vTextAlign="Middle">
				<text><![CDATA[Thank you for your business! This is a system-generated invoice for Monarch ERP]]></text>
			</element>
		</summary>
</jasperReport>