<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="MonarchERP" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a6bb1945-b50b-4e16-841b-446769f8e2e2">
    <parameter name="INVOICE_ID" class="java.lang.Long"/>
    <query language="sql"><![CDATA[

        SELECT p.product_name, v.variant_name,
               (v.colour || ' / ' || v.size) AS product_details,
               c.name, c.email, c.mobile,
               s.discount_amount, s.grand_total,
               s.invoice_number, s.invoice_date,
               si.quantity, si.unit_price, si.line_total
        FROM sales_items si
        JOIN variants v ON v.variant_id = si.variant_id
        JOIN products p ON p.product_id = v.product_id
        JOIN sales_invoices s ON s.id = si.invoice_id
        JOIN customers c ON c.id = s.customer_id
        WHERE si.invoice_id = $P{INVOICE_ID}
          AND v.deleted_variant = false
          AND p.deleted_prod = false

    ]]></query>
    <field name="product_name" class="java.lang.String"/>
    <field name="variant_name" class="java.lang.String"/>
    <field name="product_details" class="java.lang.String"/>
    <field name="quantity" class="java.lang.Integer"/>
    <field name="unit_price" class="java.lang.Double"/>
    <field name="line_total" class="java.lang.Double"/>
    <field name="discount_amount" class="java.lang.Double"/>
    <field name="invoice_number" class="java.lang.String"/>
    <field name="invoice_date" class="java.util.Date"/>
    <field name="name" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="mobile" class="java.lang.String"/>
    <variable name="SubtotalVar" calculation="Sum" class="java.lang.Double">
        <expression><![CDATA[$F{line_total}]]></expression>
    </variable>
